# Nova Agent Runtime environment template
# Copy to .env and adjust. Do not commit real secrets.

APP_NAME=nova-agent-runtime
APP_ENV=local
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8090
LOG_LEVEL=INFO
LOG_JSON=false
DEFAULT_AGENT_READONLY=true
MAX_CONCURRENT_EXECUTIONS=10
CORRELATION_HEADER=X-Correlation-Id

# Internal API authentication boundary (required for non-health endpoints)
INTERNAL_API_KEY=change_me_for_local_use
API_KEY_HEADER=X-API-Key
SERVICE_ACTOR=agent-runtime-service
