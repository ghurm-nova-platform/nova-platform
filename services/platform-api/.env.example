# Server
SERVER_PORT=8080
SPRING_APPLICATION_NAME=platform-api

# Logging
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
# Optional: enable structured JSON console logs
# SPRING_PROFILES_ACTIVE=json-logs

# Database (local Docker Compose defaults)
DATABASE_URL=jdbc:postgresql://localhost:5432/nova
DATABASE_USERNAME=nova
DATABASE_PASSWORD=nova_local_only

# JWT signing secret (>= 32 characters). Generate a unique value per environment.
# Example: openssl rand -base64 48
JWT_SECRET=
JWT_ISSUER=nova-platform
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P7D
